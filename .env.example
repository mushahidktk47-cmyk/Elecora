# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.

# --- Supabase ---
# Safe to expose to the browser (protected by Row-Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses Row-Level Security — never expose to the browser,
# never prefix with NEXT_PUBLIC_, only used inside API routes.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Provider(s) ---
# Server-only secrets. Added when the AI Tutor phase begins.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=